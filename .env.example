# Copia este archivo a .env y llena con tus credenciales reales.
# NUNCA subas .env a git (ya está en .gitignore).

# ───────────────────────────────────────────────────
# Supabase — Settings → API en tu proyecto Supabase
# ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # opcional pero recomendado para endpoints del servidor

# ───────────────────────────────────────────────────
# Plaid — https://dashboard.plaid.com → Team Settings → Keys
# ───────────────────────────────────────────────────
PLAID_CLIENT_ID=xxxxxxxxxxxxxxxx
PLAID_SECRET=xxxxxxxxxxxxxxxx                # usa el secret del entorno que vayas a probar
PLAID_ENV=sandbox                            # sandbox | development | production

# ───────────────────────────────────────────────────
# Anthropic — para Kleo AI (asesor financiero)
# ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxx

# ───────────────────────────────────────────────────
# Web Push (notificaciones) — generar con:
#   npx web-push generate-vapid-keys
# ───────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
