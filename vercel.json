{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/" }
  ],
  "crons": [
    {
      "path": "/api/push/check-payments",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/push/weekly-summary",
      "schedule": "0 13 * * 1"
    },
    {
      "path": "/api/push/ai-tips",
      "schedule": "0 17 * * *"
    }
  ]
}
